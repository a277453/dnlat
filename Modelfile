      "TDR_CV(CV)→PROCEED_NEXT",
      "TDR_PC(PC)→PROCEED_NEXT",
      "TDR_AA(GA)→CANCEL_TA",
      "TA_EVENT(GA)→CANCEL_TA",
      "TDR_SE(GA)→PROCEED_NEXT"
    ],
    "card_ejected": true,
    "response_code": "0",
    "host_decline_reason": "UNABLE TO PERFORM REQUEST",
    "app_state_start": "TRANSACTION (5)",
    "app_state_end": "OPEN (1)"
  }
]
